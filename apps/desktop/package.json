{
  "name": "@vierify/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm build && electron .",
    "lint": "tsc --noEmit -p tsconfig.json",
    "package": "pnpm build && electron-builder",
    "package:mac": "pnpm build && electron-builder --mac dmg",
    "package:win": "pnpm build && electron-builder --win nsis",
    "start": "electron .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "32.2.8",
    "electron-builder": "^26.8.1",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.vierify.merchant.desktop",
    "productName": "Vierify Merchant",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
